## .NET Core / ASP.NET Core Web API .gitignore

# Build output
bin/
obj/
out/

# Visual Studio / Rider
.vs/
.idea/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs

# Visual Studio Code
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/
project.lock.json
project.fragment.lock.json
artifacts/

# dotnet publish output
publish/
**/publish/

# Secrets & Environment
appsettings.Development.json
appsettings.Local.json
appsettings.*.local.json
*.env
.env
.env.*
secrets.json

# Entity Framework Core Migrations (optional - remove if you want to track migrations)
# **/Migrations/

# Logs
logs/
*.log
log/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Test results
TestResults/
coverage/
*.coverage
*.coveragexml
*.trx

# Rider / JetBrains
.idea/
*.sln.iml

# Docker
# (keep Dockerfile but ignore local overrides)
docker-compose.override.yml

# Certificate files
*.pfx
*.p12
*.pem
*.key
*.crt
*.cer

# Temporary files
*.tmp
*.temp
*~

# Node (if any frontend tooling is included)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Rider local history
.localhistory/
